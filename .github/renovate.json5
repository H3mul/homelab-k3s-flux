{
    "autodiscover": false,
    "dryRun": null,
    "printConfig": false,
    "dependencyDashboardAutoclose": true,
    "ignoreTests": true,
    "platform": "github",
    "repositories": ["H3mul/homelab-k3s-flux"],
    "baseBranches": ["main"],
    "ignorePaths": [
        "disabled/**",
        
        // Too critical for auto updates
        "provision/**",
        "cluster/cilium/**",
        "cluster/cilium-bgp-loadbalancer/**"
    ],
    "ignoreDeps": [
        "cilium" // Too critical for auto updates
    ],
    "extends": [
        "config:best-practices",
        ":dependencyDashboard",
        ":automergeMinor",
        ":automergeDigest",
        ":automergePatch",
        ":automergePr",
        ":disableRateLimiting",
        ":docker"
    ],
    "flux": {
        "fileMatch": ["\\.yaml$"]
    },
    "helm-values": {
        "fileMatch": ["\\.yaml$"]
    },
    "docker-compose": {
        "fileMatch": ["\\.yaml$"]
    },
}
